---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Aldo Jiménez Wiehoff' } = Astro.props;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Backend y DevOps Developer con experiencia en Node.js, Go, infraestructura Linux, Docker y Kubernetes. Ingeniero Civil Informático basado en Viña del Mar, Chile. Disponible para trabajo remoto." />
  <meta name="theme-color" content="#080808" />
  <meta name="author" content="Aldo Jiménez Wiehoff" />

  <!-- Open Graph -->
  <meta property="og:title" content="Aldo Jiménez Wiehoff — Ingeniero Civil Informático" />
  <meta property="og:description" content="Backend y DevOps Developer con experiencia en Node.js, Go, Linux, Docker y Kubernetes. Disponible para trabajo remoto." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://aldojimenezw.dev" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Aldo Jiménez Wiehoff — Ingeniero Civil Informático" />
  <meta name="twitter:description" content="Backend y DevOps Developer con experiencia en Node.js, Go, Linux, Docker y Kubernetes. Disponible para trabajo remoto." />

  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;600;700;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
    rel="stylesheet"
  />
</head>

<body>
  <slot />
</body>

  <script>
  import Lenis from 'lenis';
  import { translations } from '../i18n/translations';
  import type { Lang } from '../i18n/translations';

  // Lenis smooth scroll
  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  let lang: Lang = 'es';

  // Language toggle (ES / EN)
  function applyLang(l: Lang) {
    lang = l;
    const t = translations[l];

    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n!;
      const val = key.split('.').reduce((obj: any, k) => obj?.[k], t);
      if (typeof val === 'string') el.textContent = val;
    });

    document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach(el => {
      const key = el.dataset.i18nHtml!;
      const val = key.split('.').reduce((obj: any, k) => obj?.[k], t);
      if (typeof val === 'string') el.innerHTML = val;
    });

    // Update hero taglines (both visible and duplicate hover spans)
    const tags = document.querySelectorAll<HTMLElement>('.hero-tag');
    t.hero.tags.forEach((text, i) => {
      if (tags[i]) {
        const spans = tags[i].querySelectorAll<HTMLElement>('.tag-text');
        spans.forEach(span => span.textContent = text);
      }
    });

    buildMarquee(l);

    const btn = document.getElementById('lang-btn');
    if (btn) btn.textContent = l === 'es' ? 'EN' : 'ES';

    document.documentElement.lang = l;
  }

  function buildMarquee(l: Lang) {
    const items = translations[l].marquee;
    const track = document.getElementById('marquee-track');
    if (!track) return;
    const doubled = [...items, ...items];
    track.innerHTML = doubled.map(item =>
      `<span class="marquee-item">${item}<span class="marquee-sep"></span></span>`
    ).join('');
  }

  document.getElementById('lang-btn')?.addEventListener('click', () => {
    applyLang(lang === 'es' ? 'en' : 'es');
  });

  // Initial build
  buildMarquee('es');

  // Intro animation sequence
  const introBg   = document.getElementById('intro-bg');
  const introName = document.getElementById('intro-name');
  const heroName  = document.getElementById('hero-name');
  const navEl     = document.getElementById('nav') as HTMLElement;
  const marqueeWrap = document.getElementById('marquee-wrap');
  const heroTags  = [...document.querySelectorAll<HTMLElement>('.hero-tag')];
  const heroPhoto = document.querySelector<HTMLElement>('.hero-photo');

  if (introBg && introName && heroName) {

    setTimeout(() => {
      introBg.classList.add('dark');
      introName.classList.add('lit');
    }, 800);

    setTimeout(() => {
      const hRect = heroName.getBoundingClientRect();
      const iRect = introName.getBoundingClientRect();

      const dx = hRect.left - iRect.left;
      const dy = hRect.top  - iRect.top;

      introName.style.transition = 'transform 1.2s cubic-bezier(0.34, 1.56, 0.64, 1)';
      introName.style.transform  = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;

      setTimeout(() => {
        if (introBg) {
          introBg.style.transition = 'opacity 0.95s ease';
          introBg.classList.add('gone');
        }
      }, 500);

    }, 1800);

    setTimeout(() => {
      introBg?.remove();
      introName?.remove();

      heroName.style.transition = 'none';
      heroName.style.opacity    = '1';

      navEl?.classList.add('show');
      marqueeWrap?.classList.add('on');

      heroTags.forEach((tag, i) => {
        setTimeout(() => tag.classList.add('on'), i * 120);
      });
      setTimeout(() => heroPhoto?.classList.add('on'), 180);

    }, 3300);

  }

  // Navbar: hide on scroll down, show on scroll up
  let lastScrollY = 0;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > lastScrollY && y > 120) {
      navEl?.classList.add('hide');
    } else {
      navEl?.classList.remove('hide');
    }
    lastScrollY = y;
  }, { passive: true });

  // Scroll reveal via IntersectionObserver
  const revObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('on');
        revObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.rev').forEach(el => revObserver.observe(el));

  // Section snap: glide to nearest section after scroll stops
  const sections = [...document.querySelectorAll<HTMLElement>('.hero, .sec, .skills-section')];
  const skillsSection = document.getElementById('skills') as HTMLElement;
  const NAV_HEIGHT = 56;
  let snapTimeout: ReturnType<typeof setTimeout> | null = null;
  let isSnapping = false;
  let isInSkills = false;

  if (skillsSection) {
    const skillsObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        isInSkills = e.isIntersecting;
      });
    }, { threshold: 0.35 });
    skillsObs.observe(skillsSection);
  }

  lenis.on('scroll', () => {
    if (isSnapping || isInSkills) return;
    if (snapTimeout) clearTimeout(snapTimeout);

    snapTimeout = setTimeout(() => {
      const pos = lenis.scroll + NAV_HEIGHT + 20;
      let nearest: HTMLElement | null = null;
      let minDiff = Infinity;

      sections.forEach(sec => {
        const diff = Math.abs(pos - sec.offsetTop);
        if (diff < minDiff) {
          minDiff = diff;
          nearest = sec;
        }
      });

      // Snap only if we're off by more than 40px
      if (nearest && minDiff > 40) {
        isSnapping = true;
        lenis.scrollTo((nearest as HTMLElement).offsetTop - NAV_HEIGHT, {
          duration: 0.9,
          easing: (t: number) => 1 - Math.pow(1 - t, 3),
          onComplete: () => { isSnapping = false; },
        });
      }
    }, 120);
  });

  // Smooth anchor navigation via Lenis
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const anchor = target.closest('a[href^="#"]');
    if (!anchor) return;

    const id = (anchor as HTMLAnchorElement).getAttribute('href')!;
    const dest = document.querySelector<HTMLElement>(id);
    if (!dest) return;

    e.preventDefault();
    lenis.scrollTo(dest, {
      offset: -NAV_HEIGHT,
      duration: 1.2,
      easing: (t: number) => 1 - Math.pow(1 - t, 3),
    });
  });
</script>

</html>
