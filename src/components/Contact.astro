---
import { translations } from '../i18n/translations';

const { contacto } = translations.es;
---

<section class="sec" id="contacto">
  <p class="sec-num" data-i18n="contacto.num">06 — Contacto</p>

  <div class="contact-grid">
    <h2 class="contact-big rev" data-i18n="contacto.big">Hablemos.</h2>

    <div class="c-links rev d2">
      {contacto.links.map((link) => (
        <a
          href={link.href}
          class="c-link"
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <div>
            <p class="c-label">{link.label}</p>
            <p class="c-val">{link.value}</p>
          </div>
          <span class="c-arrow" aria-hidden="true">&#x2197;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .contact-big {
    font-family: var(--D);
    font-weight: 900;
    font-size: clamp(3.8rem, 10vw, 10rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
  }

  .c-links { display: flex; flex-direction: column; padding-top: 0.5rem; }

  .c-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--fg);
    gap: 1.5rem;
    transition: border-bottom-color 0.35s;
  }
  .c-link:first-child { border-top: 1px solid var(--border); }
  .c-link:hover { border-bottom-color: rgba(255, 255, 255, 0.38); }

  .c-label {
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .c-val { font-size: 0.88rem; }

  .c-arrow {
    font-size: 1.05rem;
    color: var(--muted);
    transition: transform 0.3s var(--spring), color 0.3s;
    flex-shrink: 0;
  }
  .c-link:hover .c-arrow {
    transform: translate(4px, -4px);
    color: var(--fg);
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-big {
      font-size: clamp(2.6rem, 9vw, 3.8rem);
    }
    .c-link {
      padding: 1rem 0;
      gap: 1rem;
    }
    .c-val {
      font-size: 0.82rem;
    }
  }
</style>
