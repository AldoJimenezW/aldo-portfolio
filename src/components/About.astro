---

<section class="sec" id="sobre">
  <p class="sec-num" data-i18n="sobre.num">01 — Sobre mí</p>

  <div class="about-grid">
    <div class="card-column rev">
      <div class="card-stack-wrap">
        <!-- Prev arrow -->
        <button class="stack-arrow stack-arrow--prev" id="stack-prev" aria-label="Tarjeta anterior">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div
          class="card-stack"
          id="card-stack"
          tabindex="0"
          aria-label="Tarjetas de información. Usa las flechas izquierda y derecha para navegar."
        >
        <div class="stack-card" data-card-idx="0">
            <img class="card-bg-img" src="/aeropress.webp" alt="" loading="lazy" />
            <div class="card-overlay"></div>
            <div class="card-content">
              <span class="card-label" data-i18n="sobre.meta.locLabel">Ubicación</span>
              <span class="card-value" data-i18n="sobre.meta.loc">Viña del Mar, Chile</span>
            </div>
          </div>

        <div class="stack-card" data-card-idx="1">
            <img class="card-bg-img" src="/chemex.jpg" alt="" loading="lazy" />
            <div class="card-overlay"></div>
            <div class="card-content">
              <span class="card-label" data-i18n="sobre.meta.rolLabel">Rol</span>
              <span class="card-value" data-i18n="sobre.meta.rol">Ingeniero Civil Informático</span>
              <div class="card-divider"></div>
              <span class="card-label" data-i18n="sobre.meta.lngLabel">Idiomas</span>
              <span class="card-value" data-i18n="sobre.meta.lng">Español (nativo) · Inglés C1</span>
            </div>
          </div>

        <div class="stack-card" data-card-idx="2">
            <img class="card-bg-img" src="/prensa_francesa.webp" alt="" loading="lazy" />
            <div class="card-overlay"></div>
            <div class="card-content">
              <span class="card-label" data-i18n="sobre.meta.staLabel">Estado</span>
              <span class="card-value" data-i18n="sobre.meta.sta">Disponible · Chile, Remoto</span>
              <div class="card-divider"></div>
              <span class="card-label" data-i18n="sobre.meta.emailLabel">Email</span>
              <a href="mailto:ajimenezw@protonmail.com" class="card-value card-link">ajimenezw@protonmail.com</a>
            </div>
          </div>
        </div>

        <!-- Next arrow -->
        <button class="stack-arrow stack-arrow--next" id="stack-next" aria-label="Tarjeta siguiente">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <div class="stack-dots" id="stack-dots">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
    </div>

    <div class="rev d1">
      <h2 class="sec-title" data-i18n="sobre.title">Quién soy</h2>
      <p class="about-bio" data-i18n-html="sobre.bio">
        Desarrollador <strong>Backend y DevOps</strong> con experiencia en
        Node.js, Go, infraestructura Linux, Docker y Kubernetes. Hábil en
        desarrollo full-stack con React, Angular y Next.js, con enfoque en
        <strong>optimización de rendimiento</strong> y arquitecturas escalables.
        Inglés C1 — disponible para trabajo remoto.
      </p>
    </div>
  </div>
</section>

<script>
  (function() {
    const stack = document.getElementById('card-stack') as HTMLElement;
    const prevBtn = document.getElementById('stack-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('stack-next') as HTMLButtonElement;
    const dots = document.querySelectorAll('#stack-dots .dot');
    if (!stack) return;

    let cards = [...stack.querySelectorAll<HTMLElement>('.stack-card')];
    const total = cards.length;
    const AUTO_INTERVAL = 5000;
    const RESUME_DELAY = 10000;

    let autoTimer: ReturnType<typeof setTimeout> | null = null;
    let resumeTimer: ReturnType<typeof setTimeout> | null = null;

    function updateStack() {
      cards = [...stack.querySelectorAll<HTMLElement>('.stack-card')];
      cards.forEach((card, i) => {
        card.classList.remove('active', 'next', 'third', 'leaving', 'entering');
        card.style.zIndex = String(total - i);

        if (i === 0) card.classList.add('active');
        else if (i === 1) card.classList.add('next');
        else card.classList.add('third');
      });

      const activeIdx = cards[0]?.dataset.cardIdx ?? '0';
      dots.forEach((d, i) => d.classList.toggle('active', String(i) === activeIdx));
    }

    function rotateForward() {
      const top = cards[0];
      top.classList.add('leaving');

      setTimeout(() => {
        top.classList.remove('leaving');
        stack.appendChild(top);
        updateStack();
      }, 650);
    }

    function rotateBackward() {
      const bottom = cards[cards.length - 1];
      bottom.classList.add('entering');
      stack.prepend(bottom);

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          bottom.classList.remove('entering');
          updateStack();
        });
      });
    }

    function startAuto() {
      if (autoTimer) clearInterval(autoTimer);
      autoTimer = setInterval(rotateForward, AUTO_INTERVAL);
    }

    function stopAuto() {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    function manualNavigate(dir: number) {
      stopAuto();
      if (resumeTimer) clearTimeout(resumeTimer);

      if (dir > 0) rotateForward();
      else rotateBackward();

      resumeTimer = setTimeout(startAuto, RESUME_DELAY);
    }

    prevBtn?.addEventListener('click', () => manualNavigate(-1));
    nextBtn?.addEventListener('click', () => manualNavigate(1));

    stack.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        manualNavigate(1);
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        manualNavigate(-1);
      }
    });

    let touchStartX = 0;
    stack.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    stack.addEventListener('touchend', (e) => {
      const touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 40) {
        manualNavigate(diff > 0 ? 1 : -1);
      }
    }, { passive: true });

    updateStack();
    startAuto();
  })();
</script>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 3fr 5fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .about-bio {
    font-size: clamp(1.05rem, 1.9vw, 1.35rem);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 300;
    max-width: 56ch;
  }
  .about-bio :global(strong) {
    color: var(--fg);
    font-weight: 500;
  }

  /* Card column */
  .card-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    min-height: 320px;
  }

  /* Stack wrapper (cards + arrows) */
  .card-stack-wrap {
    position: relative;
    width: 100%;
    max-width: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  /* Card stack */
  .card-stack {
    position: relative;
    width: 100%;
    max-width: 260px;
    height: 300px;
    perspective: 1000px;
    outline: none;
    cursor: grab;
  }
  .card-stack:active {
    cursor: grabbing;
  }
  .card-stack:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.25);
    outline-offset: 6px;
    border-radius: 4px;
  }

  .stack-card {
    position: absolute;
    inset: 0;
    border-radius: 18px;
    overflow: hidden;
    transition: transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.55s ease;
    will-change: transform, opacity;
    transform-origin: center top;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  /* Card background image */
  .card-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 18px;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: 18px;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.45) 45%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .card-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.6rem 1.4rem;
    gap: 0.35rem;
  }

  .card-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0.5rem 0;
  }

  .card-label {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
  }

  .card-value {
    font-family: var(--D);
    font-size: clamp(0.85rem, 1.3vw, 0.95rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--fg);
    word-break: break-word;
  }

  .card-link {
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
    display: inline-block;
  }
  .card-link:hover {
    border-bottom-color: rgba(255, 255, 255, 0.35);
  }

  /* Stack depth states: 3 visible cards */
  .stack-card.active {
    transform: translateY(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  .stack-card.next {
    transform: translateY(18px) rotate(9deg) scale(0.95);
    opacity: 0.65;
  }
  .stack-card.third {
    transform: translateY(36px) rotate(18deg) scale(0.90);
    opacity: 0.30;
  }

  /* Leaving animation */
  .stack-card.leaving {
    transform: translateY(-130%) rotate(-10deg) scale(0.92);
    opacity: 0;
    transition: transform 0.65s cubic-bezier(0.55, 0, 0.1, 1),
                opacity 0.45s ease;
    pointer-events: none;
  }

  /* Entering animation (backward) */
  .stack-card.entering {
    transform: translateY(100px) rotate(24deg) scale(0.78);
    opacity: 0;
  }

  /* Arrows */
  .stack-arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: var(--muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s, border-color 0.25s, color 0.25s;
    padding: 0;
  }
  .stack-arrow svg {
    width: 18px;
    height: 18px;
  }
  .stack-arrow:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.3);
    color: var(--fg);
  }
  .stack-arrow:active {
    transform: scale(0.94);
  }

  /* Dots */
  .stack-dots {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    transition: background 0.3s ease, transform 0.3s ease;
  }
  .dot.active {
    background: var(--fg);
    transform: scale(1.35);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .card-column {
      min-height: 340px;
      order: 2;
    }
    .card-stack-wrap {
      max-width: 340px;
      gap: 0.5rem;
    }
    .card-stack {
      height: 280px;
      max-width: 220px;
    }
    .stack-arrow {
      width: 36px;
      height: 36px;
    }
    .stack-arrow svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
