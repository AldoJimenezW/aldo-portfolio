---
---

<nav id="nav">
  <a href="#inicio" class="nav-logo">AJW</a>

  <ul class="nav-links">
    <li><a href="#inicio"   data-i18n="nav.inicio">Inicio</a></li>
    <li><a href="#sobre"    data-i18n="nav.sobre">Sobre mí</a></li>
    <li><a href="#exp"      data-i18n="nav.exp">Experiencia</a></li>
    <li><a href="#proyectos" data-i18n="nav.proyectos">Proyectos</a></li>
    <li><a href="#contacto" data-i18n="nav.contacto">Contacto</a></li>
  </ul>

  <div class="nav-right">
    <button class="lang-btn" id="lang-btn" aria-label="Toggle language">EN</button>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 500;
    height: 56px;
    padding: 0 clamp(1.2rem, 4vw, 2.8rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(8, 8, 8, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);

    opacity: 0;
    transform: translateY(-100%);
    transition: transform 0.44s var(--ease), opacity 0.3s ease;
  }
  nav.show { opacity: 1; transform: translateY(0); }
  nav.hide { transform: translateY(-100%); }

  .nav-logo {
    font-family: var(--D);
    font-weight: 700;
    font-size: 0.76rem;
    letter-spacing: 0.07em;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2.4rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--fg); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .lang-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--B);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.78rem;
    border-radius: 999px;
    cursor: pointer;
    text-transform: uppercase;
    transition: border-color 0.2s, color 0.2s;
  }
  .lang-btn:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: var(--fg);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
  }
</style>
